\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces (a)~Concept-count sensitivity: FPT tracks Oracle across $C \in \{2,4,6,8\}$ while all baselines fall behind, especially at large~$C$. Inset: eigengap-discovered $\hat  C$ vs.\ true $C$. (b)~Misspecified cluster count: FPT (horizontal red line) is invariant to the given $\hat  C$, while cluster-aware baselines degrade.}}{15}{figure.3}\protected@file@percent }
\newlabel{fig:concept_count}{{3}{15}{(a)~Concept-count sensitivity: FPT tracks Oracle across $C \in \{2,4,6,8\}$ while all baselines fall behind, especially at large~$C$. Inset: eigengap-discovered $\hat C$ vs.\ true $C$. (b)~Misspecified cluster count: FPT (horizontal red line) is invariant to the given $\hat C$, while cluster-aware baselines degrade}{figure.3}{}}
