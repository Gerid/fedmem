\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Protocol ordering: the core design choice.} \emph  {Top} (Scheme~A, red): existing methods cluster clients \emph  {after} local training---stale model initialisations contaminate weight updates, yielding an empirically observed clustering-error floor $\eta _A \ge 0.30$ across the datasets we study (cf.\ Theorem~\ref {thm:protocol}). \emph  {Bottom} (Scheme~C, green): FedProTrack clusters \emph  {before} training using lightweight data fingerprints, then sends concept-matched models to clients, achieving $\eta _C = 0.003$---a $200\times $ improvement.}}{2}{figure.1}\protected@file@percent }
\newlabel{fig:protocol}{{1}{2}{\textbf {Protocol ordering: the core design choice.} \emph {Top} (Scheme~A, red): existing methods cluster clients \emph {after} local training---stale model initialisations contaminate weight updates, yielding an empirically observed clustering-error floor $\eta _A \ge 0.30$ across the datasets we study (cf.\ Theorem~\ref {thm:protocol}). \emph {Bottom} (Scheme~C, green): FedProTrack clusters \emph {before} training using lightweight data fingerprints, then sends concept-matched models to clients, achieving $\eta _C = 0.003$---a $200\times $ improvement}{figure.1}{}}
